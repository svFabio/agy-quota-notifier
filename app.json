{
  "expo": {
    "name": "NotificadorTokens",
    "slug": "NotificadorTokens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "notificadortokens",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.jpg"
    },
    "android": {
      "package": "com.svfabio.notificadortokens",
      "permissions": [
        "NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#17022e",
        "foregroundImage": "./assets/images/icon.jpg",
        "backgroundImage": "./assets/images/icon.jpg",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.jpg",
          "color": "#ffffff"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#17022e",
          "image": "./assets/images/splash-icon.jpg",
          "imageWidth": 150
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c9730bf-f11c-4c07-ad38-981ceeca7ea2"
      }
    }
  }
}
